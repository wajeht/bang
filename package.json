{
    "name": "bang",
    "version": "0.0.1",
    "description": "your personal command center for blazingly fast web navigation",
    "keywords": [
        "DuckDuckGo",
        "band",
        "wajeht"
    ],
    "license": "MIT",
    "author": "wajeht",
    "type": "module",
    "main": "dist/src/server.js",
    "scripts": {
        "start": "APP_ENV=production node --env-file-if-exists=.env --no-warnings --max-old-space-size=512 ./dist/src/server.js",
        "dev:inspect": "node --env-file-if-exists=.env --run build && APP_ENV=development node --env-file-if-exists=.env --run db:prepare:prod && APP_ENV=development node --env-file-if-exists=.env --inspect ./dist/src/server.js",
        "dev:only": "APP_ENV=development node --env-file-if-exists=.env --import=tsx --watch --watch-preserve-output ./src/server.ts",
        "dev": "APP_ENV=development node --env-file-if-exists=.env --run db:prepare:dev && node --env-file-if-exists=.env --run extract:readme && APP_ENV=development exec node --env-file-if-exists=.env --import=tsx --watch --watch-preserve-output ./src/server.ts",
        "build:server": "rm -rf ./dist && tsgo",
        "build:server:prod": "tsgo -p tsconfig.json",
        "build": "node --env-file-if-exists=.env --run extract:readme && node --run build:server",
        "build:prod": "node --env-file-if-exists=.env --run extract:readme && node --run build:server:prod && node --env-file-if-exists=.env --run minify",
        "extract:readme": "node --env-file-if-exists=.env --import=tsx scripts/extract-readme.ts",
        "minify": "node --env-file-if-exists=.env --import=tsx scripts/minify.ts",
        "build:bang": "rm -rf ./src/db/bang.ts && node --env-file-if-exists=.env --import=tsx ./src/utils/banger.mts ./src/db/bang.ts",
        "build:bang:custom": "rm -rf ./src/db/bang.ts && node --env-file-if-exists=.env --import=tsx ./src/utils/banger.mts",
        "update:deps": "npx npm-check -u",
        "check:deps": "npx depcheck",
        "test:browser:headless": "node --env-file-if-exists=.env ./node_modules/playwright/cli.js test",
        "test:browser": "node --env-file-if-exists=.env ./node_modules/playwright/cli.js test --ui",
        "test:watch": "APP_ENV=testing NODE_ENV=testing NODE_NO_WARNINGS=1 vp test",
        "test": "APP_ENV=testing NODE_ENV=testing NODE_NO_WARNINGS=1 vp test --run",
        "test:coverage": "APP_ENV=testing NODE_ENV=testing vp test --run --coverage",
        "check": "vp check",
        "test:browser:server": "export APP_ENV=testing && node --no-warnings ./dist/src/server.js",
        "format:check": "vp fmt --check .",
        "format:verbose": "vp fmt --write .",
        "format": "vp fmt --write . > /dev/null",
        "lint:check": "vp lint .",
        "lint": "vp lint --fix .",
        "db:prepare:dev": "node --env-file-if-exists=.env --run db:migrate:latest && node --env-file-if-exists=.env --run db:seed:run",
        "db:prepare:prod": "node --env-file-if-exists=.env --run db:migrate:latest:prod",
        "db:migrate:make": "node --env-file-if-exists=.env --import=tsx ./node_modules/knex/bin/cli.js migrate:make --knexfile=./src/db/knexfile.ts",
        "db:migrate:latest:prod": "node --env-file-if-exists=.env ./node_modules/knex/bin/cli.js migrate:latest --knexfile=./dist/src/db/knexfile.js",
        "db:migrate:latest": "node --env-file-if-exists=.env --import=tsx ./node_modules/knex/bin/cli.js migrate:latest --knexfile=./src/db/knexfile.ts",
        "db:migrate:rollback": "node --env-file-if-exists=.env --import=tsx ./node_modules/knex/bin/cli.js migrate:rollback --knexfile=./src/db/knexfile.ts",
        "db:migrate:rollback:prod": "node --env-file-if-exists=.env ./node_modules/knex/bin/cli.js migrate:rollback --knexfile=./dist/src/db/knexfile.js",
        "db:seed:make": "node --env-file-if-exists=.env --import=tsx ./node_modules/knex/bin/cli.js seed:make --knexfile=./src/db/knexfile.ts",
        "db:seed:run": "node --env-file-if-exists=.env --import=tsx ./node_modules/knex/bin/cli.js seed:run --knexfile=./src/db/knexfile.ts",
        "db:seed:run:prod": "node --env-file-if-exists=.env ./node_modules/knex/bin/cli.js seed:run --knexfile=./dist/src/db/knexfile.js",
        "rmds": "find . -name '.DS_Store' -delete",
        "rebuild:native": "npm rebuild better-sqlite3 bcrypt esbuild --ignore-scripts=false"
    },
    "dependencies": {
        "bcrypt": "6.0.0",
        "better-sqlite3": "13.0.1",
        "compression": "1.8.1",
        "connect-flash": "0.1.1",
        "connect-session-knex": "5.0.0",
        "cors": "2.8.6",
        "csrf-sync": "4.2.1",
        "dayjs": "1.11.21",
        "esbuild": "0.28.1",
        "eta": "4.6.0",
        "express": "5.2.1",
        "express-jsdoc-swagger": "1.8.0",
        "express-rate-limit": "8.6.0",
        "express-session": "1.19.0",
        "helmet": "8.3.0",
        "highlight.js": "11.11.1",
        "isomorphic-dompurify": "3.13.0",
        "jsonwebtoken": "9.0.3",
        "knex": "3.3.0",
        "marked": "18.0.7",
        "node-cron": "4.6.0",
        "nodemailer": "9.0.3"
    },
    "devDependencies": {
        "@playwright/test": "1.61.1",
        "@types/bcrypt": "6.0.0",
        "@types/clean-css": "4.2.11",
        "@types/compression": "1.8.1",
        "@types/connect-flash": "0.0.40",
        "@types/cors": "2.8.19",
        "@types/express": "5.0.6",
        "@types/express-session": "1.19.0",
        "@types/html-minifier-terser": "7.0.2",
        "@types/jsonwebtoken": "9.0.10",
        "@types/node": "25.9.5",
        "@types/node-cron": "3.0.11",
        "@types/nodemailer": "8.0.1",
        "@types/supertest": "7.2.1",
        "@typescript/native-preview": "7.0.0-dev.20260707.2",
        "@vitest/coverage-v8": "4.1.9",
        "@wajeht/express-templates-reload": "3.0.0",
        "clean-css": "5.3.3",
        "html-minifier-terser": "7.2.0",
        "supertest": "7.2.2",
        "tsx": "4.23.1",
        "vite-plus": "0.2.2"
    },
    "overrides": {
        "glob": "13.0.6",
        "postcss": "8.5.22",
        "rimraf": "6.1.3",
        "vite": "npm:@voidzero-dev/vite-plus-core@0.2.2",
        "vitest": "4.1.9"
    },
    "engines": {
        "node": ">=26.1.0",
        "npm": ">=11.13.0"
    },
    "packageManager": "npm@11.18.0"
}
