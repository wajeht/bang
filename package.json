{
    "name": "bang",
    "version": "0.0.1",
    "description": "your personal command center for blazingly fast web navigation",
    "keywords": [
        "DuckDuckGo",
        "band",
        "wajeht"
    ],
    "license": "MIT",
    "author": "wajeht",
    "type": "module",
    "main": "dist/src/server.js",
    "scripts": {
        "start": "export APP_ENV=production && node --no-warnings --max-old-space-size=512 ./dist/src/server.js",
        "dev:inspect": "npm run build && npm run db:prepare:prod && export APP_ENV=development && node --inspect ./dist/src/server.js",
        "dev:only": "export APP_ENV=development && npm run extract:readme && tsx watch --no-warnings --clear-screen=false ./src/server.ts",
        "dev": "export APP_ENV=development && npm run db:prepare:dev && npm run extract:readme && exec tsx watch --no-warnings --clear-screen=false ./src/server.ts",
        "build:server": "rm -rf ./dist && tsgo",
        "build:server:prod": "tsgo -p tsconfig.json",
        "build": "npm run extract:readme && npm run build:server",
        "build:prod": "npm run extract:readme && npm run build:server:prod && npm run minify",
        "extract:readme": "tsx scripts/extract-readme.ts",
        "minify": "tsx scripts/minify.ts",
        "build:bang": "rm -rf ./src/db/bang.ts && tsx ./src/utils/banger.mts ./src/db/bang.ts",
        "build:bang:custom": "rm -rf ./src/db/bang.ts && tsx ./src/utils/banger.mts",
        "update:deps": "npx npm-check -u",
        "check:deps": "npx depcheck",
        "test:unit": "echo 'not yet'",
        "test:browser:headless": "npx playwright test",
        "test:browser": "npx playwright test --ui",
        "test:watch": "APP_ENV=testing NODE_ENV=testing NODE_NO_WARNINGS=1 vp test",
        "test": "APP_ENV=testing NODE_ENV=testing NODE_NO_WARNINGS=1 vp test --run",
        "test:load": "tsx ./scripts/load-test.ts",
        "test:coverage": "APP_ENV=testing NODE_ENV=testing vp test --run --coverage",
        "check": "vp check",
        "test:browser:server": "export APP_ENV=testing && node --no-warnings ./dist/src/server.js",
        "format:check": "vp fmt --check .",
        "format:verbose": "vp fmt --write .",
        "format": "vp fmt --write . > /dev/null",
        "lint:check": "vp lint .",
        "lint": "vp lint --fix .",
        "db:prepare:dev": "npm run db:migrate:latest && npm run db:seed:run",
        "db:prepare:prod": "npm run db:migrate:latest:prod",
        "db:migrate:make": "tsx ./node_modules/knex/bin/cli.js migrate:make --knexfile=./src/db/knexfile.ts",
        "db:migrate:latest:prod": "knex migrate:latest --knexfile=./dist/src/db/knexfile.js",
        "db:migrate:latest": "tsx ./node_modules/knex/bin/cli.js migrate:latest --knexfile=./src/db/knexfile.ts",
        "db:migrate:rollback": "tsx ./node_modules/knex/bin/cli.js migrate:rollback --knexfile=./src/db/knexfile.ts",
        "db:migrate:rollback:prod": "knex migrate:rollback --knexfile=./dist/src/db/knexfile.js",
        "db:seed:make": "tsx ./node_modules/knex/bin/cli.js seed:make --knexfile=./src/db/knexfile.ts",
        "db:seed:run": "tsx ./node_modules/knex/bin/cli.js seed:run --knexfile=./src/db/knexfile.ts",
        "db:seed:run:prod": "knex seed:run --knexfile=./dist/src/db/knexfile.js",
        "rmds": "find . -name '.DS_Store' -delete",
        "rebuild:native": "npm rebuild better-sqlite3 bcrypt esbuild --ignore-scripts=false"
    },
    "dependencies": {
        "bcrypt": "6.0.0",
        "better-sqlite3": "12.10.0",
        "compression": "1.8.1",
        "connect-flash": "0.1.1",
        "connect-session-knex": "5.0.0",
        "cors": "2.8.6",
        "csrf-sync": "4.2.1",
        "dayjs": "1.11.20",
        "dotenv": "17.4.2",
        "esbuild": "0.28.0",
        "eta": "4.5.1",
        "express": "5.2.1",
        "express-jsdoc-swagger": "1.8.0",
        "express-rate-limit": "8.5.1",
        "express-session": "1.19.0",
        "helmet": "8.1.0",
        "highlight.js": "11.11.1",
        "isomorphic-dompurify": "3.12.0",
        "jsonwebtoken": "9.0.3",
        "knex": "3.2.10",
        "marked": "17.0.6",
        "node-cron": "4.2.1",
        "nodemailer": "8.0.7"
    },
    "devDependencies": {
        "@playwright/test": "1.60.0",
        "@types/bcrypt": "6.0.0",
        "@types/clean-css": "4.2.11",
        "@types/compression": "1.8.1",
        "@types/connect-flash": "0.0.40",
        "@types/cors": "2.8.19",
        "@types/express": "5.0.6",
        "@types/express-session": "1.19.0",
        "@types/html-minifier-terser": "7.0.2",
        "@types/jsonwebtoken": "9.0.10",
        "@types/node": "25.7.0",
        "@types/node-cron": "3.0.11",
        "@types/nodemailer": "7.0.11",
        "@types/supertest": "7.2.0",
        "@typescript/native-preview": "7.0.0-dev.20260314.1",
        "@vitest/coverage-v8": "4.1.5",
        "@wajeht/express-templates-reload": "3.0.0",
        "clean-css": "5.3.3",
        "html-minifier-terser": "7.2.0",
        "supertest": "7.2.2",
        "tsx": "4.21.0",
        "vite-plus": "0.1.21",
        "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.21"
    },
    "overrides": {
        "glob": "13.0.6",
        "inflight": "npm:@isaacs/inflight@1.0.1",
        "postcss": "8.5.14",
        "rimraf": "6.1.3",
        "vite": "npm:@voidzero-dev/vite-plus-core@0.1.21",
        "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.21"
    },
    "engines": {
        "node": ">=26.1.0",
        "npm": ">=11.13.0"
    },
    "packageManager": "npm@11.13.0"
}
